---
import Base from '../../layouts/Base.astro';

const title = 'LeetCode Interview Prep Guides | LeetCodeAnalyzer';
const description = 'Practical guides on Blind 75 vs NeetCode 150, time complexity, interview readiness, and more. No fluff — just actionable advice.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://leetcodeanalyzer.com/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://leetcodeanalyzer.com/guides' },
  ],
};

const guides = [
  {
    href: '/guides/blind75-vs-neetcode150-vs-grind75',
    emoji: '⚖️',
    title: 'Blind 75 vs NeetCode 150 vs Grind 75: Which Should You Do?',
    desc: 'Side-by-side comparison of the three most popular LeetCode lists. Concrete recommendations based on your timeline and goals.',
    readTime: '5 min read',
  },
  {
    href: '/guides/how-to-know-if-ready-for-coding-interviews',
    emoji: '✅',
    title: 'How to Know If You\'re Ready for Coding Interviews',
    desc: 'Move beyond "I solved X problems." Concrete readiness signals that actually predict interview performance.',
    readTime: '4 min read',
  },
  {
    href: '/guides/how-to-identify-leetcode-weak-topics',
    emoji: '🎯',
    title: 'How to Identify Your LeetCode Weak Topics',
    desc: 'Pure problem count hides topic gaps. Here\'s how to find and fix yours before your next interview.',
    readTime: '4 min read',
  },
  {
    href: '/guides/how-many-leetcode-problems-should-i-solve',
    emoji: '🔢',
    title: 'How Many LeetCode Problems Should You Solve?',
    desc: 'The number question has a better answer: pattern coverage beats raw volume. Here\'s how to think about it.',
    readTime: '4 min read',
  },
  {
    href: '/guides/how-to-calculate-time-complexity',
    emoji: '⏱️',
    title: 'How to Calculate Time Complexity of Your Code',
    desc: 'Big-O from scratch — rules for counting operations, common patterns, and why constants still matter.',
    readTime: '6 min read',
  },
  {
    href: '/guides/what-makes-a-leetcode-solution-optimal',
    emoji: '🏆',
    title: 'What Makes a LeetCode Solution Optimal?',
    desc: 'Optimal isn\'t always the fastest asymptotically. Here\'s how to think about upgrade paths and interview tradeoffs.',
    readTime: '5 min read',
  },
];
---

<Base title={title} description={description} jsonLd={breadcrumbSchema}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 md:py-16 font-sans">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-xs font-mono text-ink_text-muted">
        <li><a href="/" class="hover:text-signal transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="font-medium" style="color: var(--color-text-primary);">Guides</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <p class="section-label mb-3">Resources</p>
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4 font-display" style="color: var(--color-text-primary);">
        LeetCode Interview Prep Guides
      </h1>
      <p class="text-base max-w-2xl text-ink_text-secondary">
        Practical, no-fluff guides on the questions that matter most when prepping for coding interviews.
      </p>
    </div>

    <!-- Guide grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {guides.map((g) => (
        <a
          href={g.href}
          class="card p-6 group flex flex-col gap-3 transition-all hover:-translate-y-0.5"
          aria-label={g.title}
        >
          <div class="flex items-start justify-between gap-2">
            <span class="text-3xl" aria-hidden="true">{g.emoji}</span>
            <span class="text-xs shrink-0 mt-1 rounded px-2.5 py-0.5 font-medium font-mono" style="background: rgba(217, 164, 65, 0.15); color: var(--color-signal);">{g.readTime}</span>
          </div>
          <h2 class="text-sm font-semibold leading-snug group-hover:text-signal font-display transition-colors" style="color: var(--color-text-primary);">{g.title}</h2>
          <p class="text-xs leading-relaxed flex-1 text-ink_text-muted">{g.desc}</p>
          <span class="text-xs font-medium text-signal">Read guide →</span>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <p class="text-sm mb-4 text-ink_text-muted">Ready to check your actual coverage?</p>
      <a href="/" class="btn-brand px-8 py-3">Check My LeetCode Progress →</a>
    </div>
  </div>
</Base>
