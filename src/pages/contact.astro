---
import Base from '../layouts/Base.astro';

const title = 'Contact Us | LeetCodeAnalyzer';
const description = 'Get in touch with LeetCodeAnalyzer for support, bug reports, feature requests, or privacy concerns.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://leetcodeanalyzer.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://leetcodeanalyzer.com/contact' },
  ],
};
---

<Base title={title} description={description} jsonLd={breadcrumbSchema}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 md:py-16 font-sans">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-xs font-mono text-ink_text-muted">
        <li><a href="/" class="hover:text-signal transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="font-medium text-ink_text">Contact</li>
      </ol>
    </nav>

    <article class="space-y-8 animate-fade-in">
      <header>
        <p class="section-label mb-1">Get in Touch</p>
        <h1 class="text-3xl md:text-4xl font-extrabold font-display text-ink_text">
          Contact LeetCodeAnalyzer
        </h1>
      </header>

      <section class="space-y-4">
        <p class="text-base leading-relaxed text-ink_text-secondary">
          Have a bug to report, a feature request, or questions about how we handle privacy? Email us directly — we typically respond within 2–3 business days.
        </p>
        <p class="text-lg font-semibold">
          <a href="mailto:hello@leetcodeanalyzer.com" class="text-signal hover:underline">hello@leetcodeanalyzer.com</a>
        </p>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Support card -->
        <div class="card p-5 space-y-3 flex flex-col">
          <div class="flex h-10 w-10 items-center justify-center rounded border border-signal/20 bg-signal/15 text-signal">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-sm font-display text-ink_text">Email</h3>
            <p class="text-xs mt-1 leading-relaxed text-ink_text-muted">
              General inquiries, bug reports, privacy questions, or help with Tier 2 cookie queries.
            </p>
          </div>
          <p class="text-sm font-semibold mt-auto text-signal">
            <a href="mailto:hello@leetcodeanalyzer.com" class="hover:underline">hello@leetcodeanalyzer.com</a>
          </p>
        </div>

        <!-- Feedback / Bug report card -->
        <div class="card p-5 space-y-3 flex flex-col">
          <div class="flex h-10 w-10 items-center justify-center rounded border border-signal/20 bg-signal/15 text-signal">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-sm font-display text-ink_text">GitHub Issues</h3>
            <p class="text-xs mt-1 leading-relaxed text-ink_text-muted">
              Report parser errors, request language additions, or submit pull requests.
            </p>
          </div>
          <p class="text-sm font-semibold mt-auto text-signal">
            <a href="https://github.com/leetcodeanalyzer/leetcodeanalyzer" target="_blank" rel="noopener noreferrer" class="hover:underline">leetcodeanalyzer/leetcodeanalyzer ↗</a>
          </p>
        </div>
      </div>

      <hr class="border-surface-700" />

      <section class="space-y-4">
        <h2 class="text-xl font-bold font-display text-ink_text">Reporting Bugs</h2>
        <p class="text-sm leading-relaxed text-ink_text-secondary">
          To help us resolve issues quickly, please include:
        </p>
        <ul class="list-disc pl-5 text-sm space-y-1.5 text-ink_text-secondary">
          <li>The LeetCode problem slug (e.g. <code>two-sum</code>)</li>
          <li>The language your code was written in</li>
          <li>The specific code snippet (if you are comfortable sharing, or a simplified version of it)</li>
          <li>The expected complexity vs. what our checker returned</li>
        </ul>
      </section>

      <hr class="border-surface-700" />

      <footer class="pt-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <h2 class="text-base font-bold font-display text-ink_text">Privacy concerns?</h2>
          <p class="text-xs mt-1 text-ink_text-muted">
            Read our full privacy statement to see how we guarantee your code never leaves your browser.
          </p>
        </div>
        <a href="/privacy" class="btn-ghost shrink-0 font-sans">Privacy Policy →</a>
      </footer>
    </article>
  </div>
</Base>
