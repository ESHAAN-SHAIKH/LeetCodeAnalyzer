---
import Base from '../layouts/Base.astro';

const title = 'Contact Us | LeetCodeAnalyzer';
const description = 'Get in touch with LeetCodeAnalyzer for support, bug reports, feature requests, or privacy concerns.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://leetcodeanalyzer.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://leetcodeanalyzer.com/contact' },
  ],
};
---

<Base title={title} description={description} jsonLd={breadcrumbSchema}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-xs" style="color: var(--color-text-muted);">
        <li><a href="/" class="hover:text-brand-400 transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="font-medium" style="color: var(--color-text-primary);">Contact</li>
      </ol>
    </nav>

    <article class="space-y-8 animate-fade-in">
      <header>
        <p class="section-label mb-1">Get in Touch</p>
        <h1 class="text-3xl md:text-4xl font-extrabold" style="color: var(--color-text-primary);">
          Contact LeetCodeAnalyzer
        </h1>
      </header>

      <section class="space-y-4">
        <p class="text-base leading-relaxed" style="color: var(--color-text-secondary);">
          Have a bug to report, a feature request, or questions about how we handle privacy? We want to hear from you.
          Select the most appropriate channel below for the fastest response.
        </p>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Support card -->
        <div class="card p-5 space-y-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-sm" style="color: var(--color-text-primary);">Email Support</h3>
            <p class="text-xs mt-1 leading-relaxed" style="color: var(--color-text-muted);">
              For general inquiries, account assistance, or help with Tier 2 cookie queries.
            </p>
          </div>
          <p class="text-sm font-semibold mt-auto" style="color: var(--color-brand-light);">
            <a href="mailto:contact@leetcodeanalyzer.com" class="hover:underline">contact@leetcodeanalyzer.com</a>
          </p>
        </div>

        <!-- Feedback / Bug report card -->
        <div class="card p-5 space-y-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-sm" style="color: var(--color-text-primary);">GitHub Issues</h3>
            <p class="text-xs mt-1 leading-relaxed" style="color: var(--color-text-muted);">
              Report parser errors, request language additions, or submit pull requests.
            </p>
          </div>
          <p class="text-sm font-semibold mt-auto" style="color: var(--color-brand-light);">
            <a href="https://github.com/leetcodeanalyzer/leetcodeanalyzer" target="_blank" rel="noopener noreferrer" class="hover:underline">leetcodeanalyzer/leetcodeanalyzer ↗</a>
          </p>
        </div>
      </div>

      <hr class="border-brand-500/10" />

      <section class="space-y-4">
        <h2 class="text-xl font-bold" style="color: var(--color-text-primary);">Reporting Bugs</h2>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          To help us resolve issues quickly, please include:
        </p>
        <ul class="list-disc pl-5 text-sm space-y-1.5" style="color: var(--color-text-secondary);">
          <li>The LeetCode problem slug (e.g. <code>two-sum</code>)</li>
          <li>The language your code was written in</li>
          <li>The specific code snippet (if you are comfortable sharing, or a simplified version of it)</li>
          <li>The expected complexity vs. what our checker returned</li>
        </ul>
      </section>

      <hr class="border-brand-500/10" />

      <footer class="pt-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <h2 class="text-base font-bold" style="color: var(--color-text-primary);">Privacy concerns?</h2>
          <p class="text-xs mt-1" style="color: var(--color-text-muted);">
            Read our full privacy statement to see how we guarantee your code never leaves your browser.
          </p>
        </div>
        <a href="/privacy" class="btn-ghost shrink-0">Privacy Policy →</a>
      </footer>
    </article>
  </div>
</Base>
