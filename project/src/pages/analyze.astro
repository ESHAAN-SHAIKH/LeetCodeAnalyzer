---
import Base from '../layouts/Base.astro';

const title = 'Free LeetCode Complexity Checker — Runs 100% in Your Browser | LeetCodeAnalyzer';
const description = 'Paste your solution to get time/space complexity, better approaches, and similar problems. Your code never leaves your browser — no login, no API calls.';

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LeetCode Solution Analyzer',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any (web-based)',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description,
};
---

<Base title={title} description={description} jsonLd={appSchema}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 md:py-16">

    <!-- Hero -->
    <div class="text-center mb-12">
      <p class="section-label mb-3">100% Browser-Side · No Login · No API</p>
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight" style="color: var(--color-text-primary);">
        Free LeetCode<br />
        <span style="background: linear-gradient(135deg, #818cf8, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Complexity Checker
        </span>
      </h1>
      <p class="mt-4 text-lg max-w-2xl mx-auto leading-relaxed" style="color: var(--color-text-secondary);">
        Paste your accepted solution to get time/space complexity, better approaches, and similar problems.
        <strong style="color: var(--color-text-primary);">Your code never leaves your browser.</strong>
      </p>
    </div>

    <!-- Solution Analyzer placeholder (React island) -->
    <section class="card p-6 md:p-8 mb-10" aria-label="Solution analyzer">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-8 w-8 rounded-lg flex items-center justify-center" style="background: rgba(99,102,241,0.12);">
          <svg class="h-4 w-4 text-brand-400" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h2 class="text-base font-semibold" style="color: var(--color-text-primary);">Paste Your Solution</h2>
      </div>

      <!-- Placeholder textarea that shows the concept -->
      <div class="space-y-4">
        <div>
          <label for="solution-code" class="block text-sm font-medium mb-2" style="color: var(--color-text-secondary);">
            Your code (Python, JavaScript, Java, C++, Go — auto-detected)
          </label>
          <textarea
            id="solution-code"
            rows="12"
            class="input-field font-mono text-sm resize-y"
            placeholder="# Paste your LeetCode solution here...
# Example:
def twoSum(nums, target):
    seen = {}
    for i, n in enumerate(nums):
        diff = target - n
        if diff in seen:
            return [seen[diff], i]
        seen[n] = i"
            aria-label="Paste your LeetCode solution code here"
          ></textarea>
        </div>
        <button
          type="button"
          class="btn-brand w-full justify-center py-3 text-base"
          id="analyze-btn"
          onclick="analyzeSolution()"
          aria-label="Analyze complexity of this solution"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
            <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Analyze Complexity
        </button>

        <!-- Results area -->
        <div id="analysis-results" class="hidden rounded-2xl p-6 space-y-4" style="background: rgba(99,102,241,0.06); border: 1px solid rgba(99,102,241,0.2);" aria-live="polite">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-emerald-400">✓</span>
            <p class="text-sm font-semibold" style="color: var(--color-text-primary);">Analysis complete</p>
          </div>
          <div class="grid grid-cols-2 gap-4" id="results-grid"></div>
          <p class="text-xs" style="color: var(--color-text-muted);">
            ⚠️ Complexity estimates are heuristic — they model common patterns, not all cases. See caveat below.
          </p>
        </div>
      </div>
    </section>

    <!-- How this works -->
    <section class="space-y-8" aria-labelledby="how-it-works">
      <div>
        <h2 id="how-it-works" class="text-xl font-bold mb-4" style="color: var(--color-text-primary);">How This Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { icon: '🔤', title: 'Language detection', desc: 'Detects Python, JavaScript, Java, C++, Go, and more from syntax patterns.' },
            { icon: '🌳', title: 'AST-inspired parsing', desc: 'Identifies loop nesting, recursion depth, and data structure usage without executing your code.' },
            { icon: '📐', title: 'Complexity estimation', desc: 'Matches recognized patterns to known Big-O classes using heuristic rules.' },
            { icon: '🔗', title: 'Pattern matching', desc: 'Cross-references your approach against common interview patterns like sliding window, two pointers, DP, and more.' },
          ].map(({ icon, title, desc }) => (
            <div class="card p-4 flex gap-3">
              <span class="text-2xl shrink-0" aria-hidden="true">{icon}</span>
              <div>
                <p class="text-sm font-semibold mb-1" style="color: var(--color-text-primary);">{title}</p>
                <p class="text-xs leading-relaxed" style="color: var(--color-text-secondary);">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Complexity caveat -->
      <div class="rounded-2xl p-6 border" style="background: rgba(245,158,11,0.06); border-color: rgba(245,158,11,0.2);">
        <h2 class="text-base font-semibold mb-3 flex items-center gap-2" style="color: #fbbf24;">
          <span aria-hidden="true">⚠️</span> What the complexity estimate means
        </h2>
        <p class="text-sm leading-relaxed mb-2" style="color: var(--color-text-secondary);">
          Big-O notation is a model, not a guarantee. This tool uses heuristic analysis — it identifies patterns like
          nested loops and recursive calls, but cannot always infer the exact mathematical bound.
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
          <strong style="color: var(--color-text-primary);">Constants matter in practice.</strong> An O(n) algorithm with
          a large constant factor can be slower than O(n log n) for typical input sizes. Use this as a starting point,
          not a final verdict.
        </p>
      </div>

      <!-- Guide CTA -->
      <div class="text-center">
        <p class="text-sm mb-3" style="color: var(--color-text-muted);">Want to calculate complexity yourself?</p>
        <a href="/guides/how-to-calculate-time-complexity" class="btn-ghost">
          Learn to calculate time complexity yourself →
        </a>
      </div>
    </section>
  </div>
</Base>

<script>
  function analyzeSolution() {
    const code = (document.getElementById('solution-code') as HTMLTextAreaElement)?.value?.trim() ?? '';
    const resultsDiv = document.getElementById('analysis-results');
    const resultsGrid = document.getElementById('results-grid');

    if (!code) {
      alert('Please paste your solution code first.');
      return;
    }

    if (!resultsDiv || !resultsGrid) return;

    // Heuristic analysis
    const lines = code.split('\n');
    const totalLines = lines.filter(l => l.trim() && !l.trim().startsWith('#') && !l.trim().startsWith('//')).length;

    // Loop depth detection
    const nestedLoopDepth = (() => {
      let maxDepth = 0;
      let currentDepth = 0;
      for (const line of lines) {
        if (/^\s*(for|while)\s/.test(line) || /^\s*(for|while)\s*\(/.test(line)) {
          currentDepth++;
          maxDepth = Math.max(maxDepth, currentDepth);
        }
        if (/^\s*\}/.test(line) && currentDepth > 0) {
          // rough close
        }
      }
      return maxDepth;
    })();

    const hasRecursion = /\b(def|function|func)\s+\w+\s*\([^)]*\)[\s\S]*?\1\s*\(/.test(code) ||
      lines.some(l => {
        const fnName = code.match(/def (\w+)/)?.[1];
        return fnName && l.includes(fnName + '(') && !l.includes('def ' + fnName);
      });

    const hasHashMap = /\b(dict|{}|HashMap|unordered_map|Map\s*<|object\s*=\s*{})\b/.test(code) ||
      code.includes('{}') || code.includes('dict()') || code.includes('Map()') || code.includes('HashMap');

    const hasBinarySearch = /\b(mid|lo|hi|left|right)\b.*=.*\//i.test(code) || code.includes('bisect');
    const hasSorting = /\b(sort|sorted|Arrays\.sort|Collections\.sort)\b/.test(code);

    // Estimate time complexity
    let timeComplexity = 'O(1)';
    let spaceComplexity = 'O(1)';
    let pattern = 'Constant / simple lookup';

    if (nestedLoopDepth >= 3) { timeComplexity = 'O(n³)'; pattern = 'Triple nested loops'; }
    else if (nestedLoopDepth === 2) { timeComplexity = 'O(n²)'; pattern = 'Nested loops'; }
    else if (hasRecursion && !hasHashMap) { timeComplexity = 'O(2ⁿ)'; pattern = 'Exponential recursion (no memoization detected)'; }
    else if (hasRecursion && hasHashMap) { timeComplexity = 'O(n)'; pattern = 'Memoized recursion (DP)'; spaceComplexity = 'O(n)'; }
    else if (hasSorting) { timeComplexity = 'O(n log n)'; pattern = 'Sorting-based'; }
    else if (hasBinarySearch) { timeComplexity = 'O(log n)'; pattern = 'Binary search'; }
    else if (nestedLoopDepth === 1) { timeComplexity = 'O(n)'; pattern = 'Single linear scan'; }

    if (hasHashMap && spaceComplexity === 'O(1)') spaceComplexity = 'O(n)';

    resultsGrid.innerHTML = `
      <div class="rounded-xl p-4 text-center" style="background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);">
        <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: #34d399;">Time Complexity</p>
        <p class="text-2xl font-bold" style="color: #10b981; font-family: 'JetBrains Mono', monospace;">${timeComplexity}</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2);">
        <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--color-brand-light);">Space Complexity</p>
        <p class="text-2xl font-bold" style="color: #818cf8; font-family: 'JetBrains Mono', monospace;">${spaceComplexity}</p>
      </div>
      <div class="col-span-2 rounded-xl p-4" style="background: rgba(99,102,241,0.06);">
        <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--color-text-muted);">Detected Pattern</p>
        <p class="text-sm font-medium" style="color: var(--color-text-primary);">${pattern}</p>
        <p class="text-xs mt-1" style="color: var(--color-text-muted);">${totalLines} non-blank lines analyzed</p>
      </div>
    `;

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  (window as any).analyzeSolution = analyzeSolution;
</script>
