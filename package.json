    "typecheck": "astro check",
    "lint": "eslint src --ext .js,.ts,.tsx,.astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
