    "@babel/traverse": "^8.0.4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/acorn": "^4.0.6",
    "@types/babel__traverse": "^7.28.0",
    "@types/d3": "^7.4.3",
    "@types/estree": "^1.0.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "acorn": "^8.17.0",
    "astro": "^7.0.7",
    "autoprefixer": "^10.5.2",
    "d3": "^7.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
