    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "serve": "^14.2.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
